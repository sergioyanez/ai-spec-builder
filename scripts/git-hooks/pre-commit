#!/usr/bin/env bash
# Pre-commit hook: blocks commits that introduce hardcoded API keys or secrets.
# Installed via `git config core.hooksPath scripts/git-hooks` (see scripts/setup-hooks.sh).
set -euo pipefail

# Files that legitimately contain long hashes/lockfile noise, not secrets.
EXCLUDE_REGEX='(^|/)(package-lock\.json|pnpm-lock\.yaml|yarn\.lock)$'

# Placeholder-looking values that should not trigger the generic heuristic.
PLACEHOLDER_REGEX='(your|example|xxx|changeme|placeholder|insert|replace|dummy|<|>|todo|here|redacted)'

staged_files=$(git diff --cached --name-only --diff-filter=ACMR || true)

if [ -z "$staged_files" ]; then
  exit 0
fi

found=0
report=""

add_finding() {
  local file="$1" line="$2" match="$3" rule="$4"
  found=1
  report="${report}\n  ${file}:${line}  [${rule}]\n    ${match}\n"
}

while IFS= read -r file; do
  [ -z "$file" ] && continue
  if echo "$file" | grep -qE "$EXCLUDE_REGEX"; then
    continue
  fi

  content=$(git show ":${file}" 2>/dev/null || true)
  [ -z "$content" ] && continue

  # Specific, high-confidence secret formats.
  while IFS=: read -r line match; do
    [ -z "${line:-}" ] && continue
    add_finding "$file" "$line" "$match" "anthropic-key"
  done < <(printf '%s\n' "$content" | grep -nIE 'sk-ant-[A-Za-z0-9_-]{20,}' || true)

  while IFS=: read -r line match; do
    [ -z "${line:-}" ] && continue
    add_finding "$file" "$line" "$match" "openai-key"
  done < <(printf '%s\n' "$content" | grep -nIE 'sk-(proj-)?[A-Za-z0-9]{32,}' || true)

  while IFS=: read -r line match; do
    [ -z "${line:-}" ] && continue
    add_finding "$file" "$line" "$match" "aws-access-key-id"
  done < <(printf '%s\n' "$content" | grep -nIE '\b(AKIA|ASIA)[0-9A-Z]{16}\b' || true)

  while IFS=: read -r line match; do
    [ -z "${line:-}" ] && continue
    add_finding "$file" "$line" "$match" "github-token"
  done < <(printf '%s\n' "$content" | grep -nIE '\b(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{36}\b|github_pat_[A-Za-z0-9_]{22,}' || true)

  while IFS=: read -r line match; do
    [ -z "${line:-}" ] && continue
    add_finding "$file" "$line" "$match" "slack-token"
  done < <(printf '%s\n' "$content" | grep -nIE '\bxox[baprs]-[A-Za-z0-9-]{10,}\b' || true)

  while IFS=: read -r line match; do
    [ -z "${line:-}" ] && continue
    add_finding "$file" "$line" "$match" "private-key-block"
  done < <(printf '%s\n' "$content" | grep -nIE -- '-----BEGIN (RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY-----' || true)

  # Generic heuristic: name-like-a-secret assigned a quoted literal.
  while IFS=: read -r line match; do
    [ -z "${line:-}" ] && continue
    if echo "$match" | grep -qiE "$PLACEHOLDER_REGEX"; then
      continue
    fi
    add_finding "$file" "$line" "$match" "generic-secret-assignment"
  done < <(printf '%s\n' "$content" | grep -nIE '(api[_-]?key|secret|token|password|passwd|access[_-]?key|client[_-]?secret)[[:space:]]*[:=][[:space:]]*["'"'"'][A-Za-z0-9_/+=.-]{12,}["'"'"']' || true)

done <<< "$staged_files"

if [ "$found" -eq 1 ]; then
  echo ""
  echo "=========================================================="
  echo " COMMIT BLOCKED: possible API key or secret detected"
  echo "=========================================================="
  echo -e "$report"
  echo "Remove the secret (use environment variables instead) before committing."
  echo "If this is a false positive, adjust scripts/git-hooks/pre-commit."
  echo "=========================================================="
  exit 1
fi

exit 0
